@model CloverleafThrows.Models.WorkoutDay
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Day @Model.DayNumber — @Model.Date.ToString("MMM d, yyyy") — Cloverleaf Throws</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/site.css" />
    <style>
        body { background: white; padding: 0; }
        .print-page { max-width: 1100px; margin: 0 auto; padding: 1.5rem; }
        .print-header { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.25rem; background: #1a2332; border-radius: 10px; margin-bottom: 1.5rem; }
        .print-header-left h1 { font-size: 1.5rem; font-weight: 700; color: white; }
        .print-header-left .sub { color: rgba(255,255,255,0.6); font-size: 0.875rem; }
        .print-header-tags { display: flex; gap: 0.5rem; }
        .print-footer { margin-top: 1.5rem; display: flex; justify-content: space-between; font-size: 0.75rem; color: #9ca3af; }
        .print-btn { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 100; }
        @@media print { .print-btn { display: none; } .print-page { padding: 0; max-width: none; } @@page { size: landscape; margin: 0.4in; } }
    </style>
</head>
<body>
    <div class="print-page">
        <div class="print-header">
            <div class="print-header-left">
                <h1>Day @Model.DayNumber &mdash; @Model.DayType</h1>
                <div class="sub">@Model.Date.ToString("dddd, MMMM d, yyyy")</div>
            </div>
            <div class="print-header-tags">
                <span class="tag" style="background:@Model.DayTypeColor;color:@Model.DayTypeTextColor">@Model.DayType</span>
                @if (!string.IsNullOrEmpty(Model.ThrowsFocus))
                { <span class="tag" style="background:@Model.ThrowsFocusColor;color:@Model.ThrowsFocusTextColor">@Model.ThrowsFocus</span> }
            </div>
        </div>

        <div class="workout-sections">
            <div>
                @{ var throwTitle = !string.IsNullOrEmpty(Model.ThrowsFocus) ? $"Throwing — {Model.ThrowsFocus}" : "Throwing";
                   var throwBg = Model.ThrowsFocus == "Shot Put" ? "#C55A11" : "#1F4E79"; }
                @{ var warmupVd = new ViewDataDictionary(ViewData); warmupVd["Title"] = "Throws Warmup"; warmupVd["BgColor"] = "#1F4E79"; warmupVd["TextColor"] = "#fff"; warmupVd["Section"] = Model.ThrowsWarmup; }
                @await Html.PartialAsync("_SectionCard", warmupVd)
                <div style="height:0.75rem;"></div>
                @{ var throwingVd = new ViewDataDictionary(ViewData); throwingVd["Title"] = throwTitle; throwingVd["BgColor"] = throwBg; throwingVd["TextColor"] = "#fff"; throwingVd["Section"] = Model.Throwing; }
                @await Html.PartialAsync("_SectionCard", throwingVd)
                @if (!string.IsNullOrEmpty(Model.CoachNotes))
                { <div class="coach-notes" style="margin-top:0.75rem;"><div class="coach-notes-label">Coach Notes</div><p>@Model.CoachNotes</p></div> }
            </div>
            <div>
                @{ var liftTitle = Model.DayType == "Jump / Sprint" ? "Jump / Sprint Session" : Model.DayType == "Throwing Only" ? "Rest Day" : "Lifting";
                   var liftBg = Model.DayType == "Jump / Sprint" ? "#7F6000" : "#1F4E79"; }
                @{ var liftingVd = new ViewDataDictionary(ViewData); liftingVd["Title"] = liftTitle; liftingVd["BgColor"] = liftBg; liftingVd["TextColor"] = "#fff"; liftingVd["Section"] = Model.Lifting; }
                @await Html.PartialAsync("_SectionCard", liftingVd)
            </div>
            <div>
                @{ var mobilityVd = new ViewDataDictionary(ViewData); mobilityVd["Title"] = "Mobility"; mobilityVd["BgColor"] = "#375623"; mobilityVd["TextColor"] = "#fff"; mobilityVd["Section"] = Model.Mobility; }
                @await Html.PartialAsync("_SectionCard", mobilityVd)
                <div style="height:0.75rem;"></div>
                @{ var coreVd = new ViewDataDictionary(ViewData); coreVd["Title"] = "Core"; coreVd["BgColor"] = "#4A3670"; coreVd["TextColor"] = "#fff"; coreVd["Section"] = Model.Core; }
                @await Html.PartialAsync("_SectionCard", coreVd)
            </div>
        </div>
        <div class="print-footer">
            <span>Cloverleaf Throws &mdash; @Model.MesocycleName</span>
            <span>Day @Model.DayNumber</span>
        </div>
    </div>
    <button class="btn btn-primary print-btn" onclick="window.print()">Print</button>
</body>
</html>
