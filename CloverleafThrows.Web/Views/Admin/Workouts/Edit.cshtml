@model CloverleafThrows.Models.WorkoutEditViewModel
@{
    Layout = "~/Views/Admin/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.Day.Id > 0 ? $"Edit Day {Model.Day.DayNumber}" : "New Workout Day";
    var isNew = Model.Day.Id == 0;
    var dayTypes = new[] { "Oly / Lower", "Upper Body", "Throwing Only", "Jump / Sprint", "Full Body" };
    var focusOptions = new[] { "Shot Put", "Discus" };
}

<div class="admin-page-header">
    <div>
        <h1>@(isNew ? "New Workout Day" : $"Day {Model.Day.DayNumber} — {Model.Day.Date:ddd, MMM d}")</h1>
        @if (!isNew)
        {
            <div style="display:flex; gap:0.375rem; margin-top:0.375rem;">
                <span class="tag" style="background:@Model.Day.DayTypeColor;color:@Model.Day.DayTypeTextColor">@Model.Day.DayType</span>
                <span class="tag" style="background:@Model.Day.ThrowsFocusColor;color:@Model.Day.ThrowsFocusTextColor">@Model.Day.ThrowsFocus</span>
            </div>
        }
    </div>
    <div style="display:flex; gap:0.375rem;">
        @if (!isNew)
        {
            <a href="/Workout/Detail?date=@Model.Day.Date.ToString("yyyy-MM-dd")" class="btn" target="_blank">Preview</a>
            <a href="/Workout/Print?date=@Model.Day.Date.ToString("yyyy-MM-dd")" class="btn" target="_blank">Print</a>
            <form method="post" action="/Admin/Workouts/SwapFocus" style="display:inline;">
                <input type="hidden" name="id" value="@Model.Day.Id" />
                <button type="submit" class="btn">Swap to @(Model.Day.ThrowsFocus == "Shot Put" ? "Discus" : "Shot Put")</button>
            </form>
        }
        @if (!isNew)
        {
            <form method="post" action="/Admin/Workouts/Delete" style="display:inline;"
                  onsubmit="return confirm('Delete Day @Model.Day.DayNumber? This cannot be undone.');">
                <input type="hidden" name="id" value="@Model.Day.Id" />
                <input type="hidden" name="mesocycleId" value="@Model.MesocycleId" />
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        }
        <a href="/Admin/Workouts?mesocycleId=@Model.MesocycleId" class="btn">Back to List</a>
    </div>
</div>

@* Day properties form *@
<div class="admin-card">
    <div class="admin-card-title" style="margin-bottom:1rem;">Day Properties</div>
    <form method="post" action="/Admin/Workouts/@(isNew ? "Create" : "Edit")">
        <input type="hidden" name="Id" value="@Model.Day.Id" />
        <input type="hidden" name="MesocycleId" value="@Model.MesocycleId" />

        <div class="form-row-3">
            <div class="form-group">
                <label class="form-label">Day Number</label>
                <input type="number" name="DayNumber" value="@Model.Day.DayNumber" class="form-input" required />
            </div>
            <div class="form-group">
                <label class="form-label">Date</label>
                <input type="date" name="Date" value="@Model.Day.Date.ToString("yyyy-MM-dd")" class="form-input" required />
            </div>
            <div class="form-group">
                <label class="form-label">Day Type</label>
                <select name="DayType" class="form-select">
                    @foreach (var dt in dayTypes)
                    {
                        <option value="@dt" selected="@(Model.Day.DayType == dt)">@dt</option>
                    }
                </select>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Throws Focus</label>
                <select name="ThrowsFocus" class="form-select">
                    @foreach (var f in focusOptions)
                    {
                        <option value="@f" selected="@(Model.Day.ThrowsFocus == f)">@f</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Coach Notes</label>
                <textarea name="CoachNotes" class="form-textarea" rows="2">@Model.Day.CoachNotes</textarea>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">@(isNew ? "Create Day" : "Save Properties")</button>
            @if (!isNew)
            {
                <form method="post" action="/Admin/Workouts/Delete" style="display:inline; margin-left:auto;">
                    <input type="hidden" name="id" value="@Model.Day.Id" />
                    <input type="hidden" name="mesocycleId" value="@Model.MesocycleId" />
                    <button type="submit" class="btn" style="color:#a32d2d;"
                            onclick="return confirm('Delete this workout day? This cannot be undone.')">Delete Day</button>
                </form>
            }
        </div>
    </form>
</div>

@* Duplicate form *@
@if (!isNew)
{
    <div class="admin-card">
        <div class="admin-card-header">
            <div class="admin-card-title">Duplicate This Day</div>
        </div>
        <form method="post" action="/Admin/Workouts/Duplicate" style="display:flex; gap:0.75rem; align-items:end;">
            <input type="hidden" name="id" value="@Model.Day.Id" />
            <div class="form-group" style="margin:0;">
                <label class="form-label">New Date</label>
                <input type="date" name="newDate" class="form-input" required />
            </div>
            <div class="form-group" style="margin:0;">
                <label class="form-label">Day Number</label>
                <input type="number" name="newDayNumber" class="form-input" style="width:5rem;" required />
            </div>
            <button type="submit" class="btn btn-primary">Duplicate</button>
        </form>
    </div>
}

@* Exercise editor per section *@
@if (!isNew && Model.Day.Sections.Any())
{
    <div style="margin-top:1.5rem;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem;">
            <h2 style="font-size:1.125rem; font-weight:700;">Exercises</h2>
        </div>

        @foreach (var sect in Model.Day.Sections.OrderBy(s => s.SortOrder))
        {
            var bgColor = sect.HeaderColor ?? "#1F4E79";
            <div class="workout-editor-section" data-section-id="@sect.Id">
                <div class="workout-editor-section-header" style="background:@bgColor;">
                    <span class="workout-editor-section-title">@sect.Name</span>
                    <button class="btn" style="font-size:0.6875rem; padding:0.2rem 0.5rem; background:rgba(255,255,255,0.15); color:white; border-color:rgba(255,255,255,0.2);"
                            onclick="addGroup(@sect.Id)">+ Group</button>
                </div>

                @foreach (var grp in sect.Groups.OrderBy(g => g.SortOrder))
                {
                    <div class="exercise-group-container" data-group-id="@grp.Id">
                        @if (!string.IsNullOrEmpty(grp.Label))
                        {
                            <div class="exercise-group-label" style="font-size:0.6875rem; padding:0.25rem 0.5rem; background:var(--gray-50); border-bottom:1px solid var(--gray-100); display:flex; justify-content:space-between; align-items:center;">
                                <span>@grp.Label</span>
                            </div>
                        }

                        <div class="exercise-list" data-group-id="@grp.Id">
                            @foreach (var ex in grp.Exercises.OrderBy(e => e.SortOrder))
                            {
                                <div class="exercise-edit-row" data-exercise-id="@ex.Id">
                                    <span class="drag-handle" title="Drag to reorder">&#x2630;</span>
                                    <input type="text" class="num-input" value="@ex.Number" placeholder="#"
                                           onchange="updateExercise(@ex.Id, this.parentElement)" />
                                    <input type="text" class="name-input" value="@ex.ExerciseName" placeholder="Exercise name"
                                           onchange="updateExercise(@ex.Id, this.parentElement)" />
                                    <input type="text" class="reps-input" value="@ex.Reps" placeholder="Reps"
                                           onchange="updateExercise(@ex.Id, this.parentElement)" />
                                    <button class="delete-btn" onclick="deleteExercise(@ex.Id, this.parentElement)" title="Remove">
                                        &times;
                                    </button>
                                </div>
                            }
                        </div>

                        <button class="btn" style="font-size:0.6875rem; padding:0.2rem 0.5rem; margin:0.25rem 0 0.5rem 1.75rem;"
                                onclick="addExercise(@grp.Id)">+ Exercise</button>
                    </div>
                }
            </div>
        }
    </div>
}
else if (!isNew)
{
    <div class="admin-card" style="text-align:center; padding:2rem; margin-top:1rem;">
        <p style="color:var(--text-muted);">No sections yet. Add the standard sections to get started.</p>
        <button class="btn btn-primary" style="margin-top:0.5rem;" onclick="addDefaultSections(@Model.Day.Id)">
            Add Standard Sections
        </button>
    </div>
}

@* Hidden exercise library for autocomplete *@
<script id="exercise-library" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExerciseLibrary.Select(e => new { e.Id, e.Name, e.DefaultReps, e.CategoryName })))</script>

@section Scripts {
<script src="/js/workout-editor.js"></script>
}
