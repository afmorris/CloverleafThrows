@{
    var currentPath = Context.Request.Path.Value?.ToLower() ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin — Cloverleaf Throws</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="admin-body">
    <aside class="admin-sidebar">
        <a href="/Admin/Dashboard" class="admin-brand">
            <span class="admin-brand-icon">🏋️</span>
            <span>Cloverleaf Throws</span>
        </a>

        <nav class="admin-nav">
            <div class="admin-nav-group">
                <div class="admin-nav-label">Training</div>
                <a href="/Admin/Dashboard" class="admin-nav-link @(currentPath.EndsWith("dashboard") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    Dashboard
                </a>
                <a href="/Admin/Workouts" class="admin-nav-link @(currentPath.Contains("workouts") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Workouts
                </a>
                <a href="/Admin/Mesocycles" class="admin-nav-link @(currentPath.Contains("mesocycles") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Mesocycles
                </a>
                <a href="/Admin/Exercises" class="admin-nav-link @(currentPath.Contains("exercises") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    Exercise Library
                </a>
                <a href="/Admin/SeasonOverview" class="admin-nav-link @(currentPath.Contains("seasonoverview") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    Training Load
                </a>
            </div>

            <div class="admin-nav-group">
                <div class="admin-nav-label">Team</div>
                <a href="/Admin/Athletes" class="admin-nav-link @(currentPath.Contains("athletes") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Athletes
                </a>
                <a href="/Admin/Meets" class="admin-nav-link @(currentPath.Contains("meets") ? "active" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Meets
                </a>
            </div>
        </nav>

        <div class="admin-sidebar-footer">
            <a href="/" class="admin-nav-link" target="_blank" style="font-size:0.75rem; margin-top:0.25rem;">
                View Public Site &rarr;
            </a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-content">
            @RenderBody()
        </div>
    </main>

    <script src="~/js/site.js"></script>
    <script src="~/js/admin.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
